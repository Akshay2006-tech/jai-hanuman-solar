# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/solar-recycle
# Replace above with your MongoDB Atlas connection string after setup
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/solar-recycle

# Session Configuration
SESSION_SECRET=solar-recycle-secret-key-change-this-in-production

# Server Configuration
PORT=3000

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev
